# ─── Supabase ────────────────────────────────────────────────────────────────
# Required: Get these from your Supabase project settings > API
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.your-anon-key
VITE_SUPABASE_PROJECT_ID=your-project-ref

# ─── Supabase Edge Function Secrets (set via: supabase secrets set KEY=value) ─
# These are NOT prefixed with VITE_ – they are server-side only

# AI gateway (Lovable)
# LOVABLE_API_KEY=your-lovable-api-key

# WhatsApp / Z-API
# ZAPI_INSTANCE_ID=your-zapi-instance-id
# ZAPI_TOKEN=your-zapi-token
# ZAPI_CLIENT_TOKEN=your-zapi-client-token

# Meta Cloud API (Official WhatsApp Business)
# META_WA_ACCESS_TOKEN=your-meta-access-token
# META_WEBHOOK_VERIFY_TOKEN=your-custom-verify-token   ← change from default!

# Email (Resend)
# RESEND_API_KEY=re_your-api-key

# SMS
# SMSDEV_API_KEY=your-smsdev-key
# SMSBARATO_USERNAME=your-username
# SMSBARATO_PASSWORD=your-password
# DISPAROPRO_API_KEY=your-disparopro-key

# Firecrawl (web scraping for Knowledge Base)
# FIRECRAWL_API_KEY=your-firecrawl-key

# Passkit (digital wallet passes)
# PASSKIT_API_KEY=your-passkit-key

# Perplexity AI
# PERPLEXITY_API_KEY=your-perplexity-key

# Webhook shared secret – append ?secret=<value> to your webhook URLs
# WEBHOOK_SECRET=generate-a-strong-random-secret-here

# App base URL (used in affiliate links, emails, etc.)
# APP_BASE_URL=https://your-app-domain.com
